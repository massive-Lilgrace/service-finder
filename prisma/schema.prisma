generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model provider {
  id             Int      @id @default(autoincrement())
  email          String   @unique(map: "Provider_email_key")
  businessName   String
  category       String
  phoneNumber    String
  address        String
  city           String
  about          String?  @db.Text
  profilePicture String?
  basePrice      Float    @default(0)
  rating         Float    @default(5)
  reviewCount    Int      @default(0)
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@index([category], map: "Provider_category_idx")
  @@index([city], map: "Provider_city_idx")
}

model booking {
  id           Int      @id @default(autoincrement())
  customerName String
  phoneNumber  String
  assignedTask String
  dateTime     String
  status       String   @default("Pending")
  providerId   Int
  createdAt    DateTime @default(now())

  @@index([providerId], map: "Booking_providerId_idx")
}